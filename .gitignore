# =========================================================================
# SECURITY: Environment Configuration Files & Secrets
# =========================================================================
# Never upload secret API keys, database URLs, or login passwords to GitHub!
.env
.envv
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================================================================
# DEPENDENCIES: Packages & Heavy Third-Party Folders
# =========================================================================
# These can be regenerated anytime by running 'npm install'
node_modules/
jspm_packages/
web_modules/

# =========================================================================
# LOGS & DIAGNOSTICS: Debugging Files
# =========================================================================
# Keeps system crash reports and debug histories off your GitHub repository
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================================================================
# OPERATING SYSTEM SPECIFIC: Local Machine Metadata
# =========================================================================
# Hidden thumbnail caches and workspace metadata files created by your computer
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# =========================================================================
# IDE / TEXT EDITORS: Local Code Editor Settings
# =========================================================================
# Keeps your personal code editor preferences from overriding your teammate's settings
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp